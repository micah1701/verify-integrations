{
  "name": "verify-integrations-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:storefront && npm run build:admin",
    "build:storefront": "vite build --config vite.storefront.config.ts",
    "build:admin": "vite build --config vite.admin.config.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "postbuild:server": "node -e \"require('fs').writeFileSync('dist/server/package.json', JSON.stringify({type:'commonjs'}))\"",
    "dev:admin": "vite --config vite.admin.config.ts",
    "dev:server": "tsx watch server/index.ts",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "react": "^18",
    "react-dom": "^18",
    "@bigcommerce/big-design": "^2",
    "styled-components": "^5.3.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5",
    "vite": "^5",
    "@vitejs/plugin-react": "^4",
    "@sveltejs/vite-plugin-svelte": "^3",
    "svelte": "^4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "tsx": "^4.7.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20"
  }
}
