# BigCommerce App Credentials
# Obtained from https://devtools.bigcommerce.com after registering the app
BC_CLIENT_ID=
BC_CLIENT_SECRET=

# Deployment
# The public URL of this server (no trailing slash)
APP_BASE_URL=https://verify-integrations.ad-hoc.app

# Ad-Hoc Verify API
ADHOC_API_BASE=https://verify-api.ad-hoc.app

# Server
PORT=3000

# Storage
# Path to the JSON token store file (created automatically on first run)
DATABASE_PATH=./data/tokens.json
